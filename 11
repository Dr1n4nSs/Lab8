public static void SaveDatabase(string path, List<Exhibit> list)
{
    try
    {
        string directory = Path.GetDirectoryName(path);

        if (!string.IsNullOrEmpty(directory) && !Directory.Exists(directory))
        {
            Directory.CreateDirectory(directory);
            Console.WriteLine($"Создана недостающая директория: {directory}");
        }

        using (BinaryWriter writer = new BinaryWriter(File.Open(path, FileMode.Create)))
        {
            writer.Write(list.Count);
            foreach (var ex in list)
            {
                writer.Write(ex.InventoryNumber ?? "");
                writer.Write(ex.Title ?? "");
                writer.Write(ex.CreationYear);
                writer.Write(ex.Value);
                writer.Write(ex.IsRestored);
            }
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Критическая ошибка при сохранении: {ex.Message}");
    }
}
